[init]
    defaultBranch = main
    templatedir = ~/.config/git/template

[core]
    editor = vim      # 'vim', 'nvim', or 'code --wait'
    pager = less -FRX
    # Prevents Windows CRLF line ending nightmares ('true' on Windows, 'input' on Mac/Linux)
    autocrlf = input
    excludesfile = ~/.config/git/ignore
    whitespace = trailing-space,space-before-tab

[commit]
    verbose = true           # Include diff comment in commit message template
    gpgsign = true

[gpg]
    format = ssh

[color]
    ui = auto

[pull]
    rebase = true   # Rebase (instead of merge) on pull for linear history

[push]
    autoSetupRemote = true   # Automatically set upstream branch on push

[fetch]
    # Cleans up local tracking branches that were deleted on GitHub/GitLab
    prune = true
    pruneTags = true

[rebase]
    autoStash = true
    autoSquash = true

[merge]
    # Much better conflict layout than default (shows common ancestor and code compaction), Includes the base text block in conflict markers, making complex conflicts much easier to resolve
    conflictstyle = zdiff3

[diff]
    algorithm = histogram    # Clearer diffs on moved/edited lines
    colorMoved = plain       # Highlight moved blocks in diffs
    mnemonicPrefix = true    # More intuitive refs in diff output
    renames = true


[column]
    ui = auto                # Output in columns when possible

[branch]
    sort = -committerdate    # Sort branches by most recent commit first

[log]
    date = iso

[alias]
    st = status -sb
    ; lg = log --oneline --graph --decorate --all
    lg = log --graph --abbrev-commit --decorate --format=format:'%C(bold blue)%h%C(reset) - %C(bold green)(%ar)%C(reset) %C(white)%s%C(reset) %C(dim white)- %an%C(reset)%C(bold yellow)%d%C(reset)' --all

    # Uncommits the last commit, leaves files STAGED (ready to commit again)
    undo = reset --soft HEAD~1

    # Undo the last commit, leaves files UNSTAGED (wipes the staging area)
    unstage = reset HEAD~1

    ; amend = commit --amend --no-edit
    ; please = push --force-with-lease
    ; oops   = commit --amend

[help]
    # Typo corrector (e.g., `git stats` will prompt to run `git status`)
    autocorrect = prompt
